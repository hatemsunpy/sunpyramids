{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs pre-bash",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs pre-edit",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs post-edit",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs post-bash",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [],
    "SessionStart": [],
    "SessionEnd": [],
    "Stop": [],
    "PreCompact": [],
    "SubagentStart": [],
    "SubagentStop": [],
    "Notification": []
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c 'exec node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/statusline.cjs\"'"
  },
  "permissions": {
    "allow": [
      "Bash(npx @claude-flow*)",
      "Bash(npx claude-flow*)",
      "Bash(node .claude/*)",
      "mcp__claude-flow__:*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "attribution": {
    "commit": "Co-Authored-By: RuFlo <ruv@ruv.net>",
    "pr": "🤖 Generated with [RuFlo](https://github.com/ruvnet/ruflo)"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "CLAUDE_FLOW_V3_ENABLED": "false",
    "CLAUDE_FLOW_HOOKS_ENABLED": "false"
  },
  "claudeFlow": {
    "version": "3.0.0",
    "enabled": false,
    "platform": {
      "os": "windows",
      "arch": "x64",
      "shell": "powershell"
    },
    "modelPreferences": {
      "default": "claude-opus-4-7",
      "routing": "claude-haiku-4-5-20251001"
    },
    "agentTeams": {
      "enabled": false,
      "teammateMode": "auto",
      "taskListEnabled": false,
      "mailboxEnabled": false,
      "coordination": {
        "autoAssignOnIdle": false,
        "trainPatternsOnComplete": false,
        "notifyLeadOnComplete": false,
        "sharedMemoryNamespace": "agent-teams"
      },
      "hooks": {
        "teammateIdle": {
          "enabled": false,
          "autoAssign": false,
          "checkTaskList": false
        },
        "taskCompleted": {
          "enabled": false,
          "trainPatterns": false,
          "notifyLead": false
        }
      }
    },
    "swarm": {
      "topology": "hierarchical-mesh",
      "maxAgents": 15
    },
    "memory": {
      "backend": "hybrid",
      "enableHNSW": false,
      "learningBridge": {
        "enabled": false
      },
      "memoryGraph": {
        "enabled": false
      },
      "agentScopes": {
        "enabled": false
      }
    },
    "neural": {
      "enabled": false
    },
    "daemon": {
      "autoStart": false,
      "workers": [],
      "schedules": {}
    },
    "learning": {
      "enabled": false,
      "autoTrain": false,
      "patterns": [],
      "retention": {
        "shortTerm": "24h",
        "longTerm": "30d"
      }
    },
    "adr": {
      "autoGenerate": false,
      "directory": "/docs/adr",
      "template": "madr"
    },
    "ddd": {
      "trackDomains": false,
      "validateBoundedContexts": false,
      "directory": "/docs/ddd"
    },
    "security": {
      "autoScan": false,
      "scanOnEdit": false,
      "cveCheck": false,
      "threatModel": false
    }
  }
}